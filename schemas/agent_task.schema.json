{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/agent_task.schema.json",
  "title": "Agent Task",
  "type": "object",
  "required": [
    "task_id",
    "agent",
    "goal",
    "inputs",
    "constraints"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "agent": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expected_output_schema": {
      "type": "string"
    }
  }
}
