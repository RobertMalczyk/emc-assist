# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.pytest_cache/
.coverage
build/
dist/
*.so

# Virtual environments
.venv/
venv/
env/

# Editors / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Claude Code local state (per-user)
.claude/settings.local.json

# Generated project artefacts in examples (regenerated by CLI)
examples/**/generated/
examples/**/results/
examples/**/reports/
examples/**/decisions/

# LTspice user artefacts
*.raw
*.op.raw
*.log
*.net

# Secrets — never commit
.openai_key
.env
.env.local
*.secret

# Knowledge tier contents — track READMEs only
knowledge/raw_sources/*
!knowledge/raw_sources/README.md
!knowledge/raw_sources/.gitkeep
knowledge/user_private_sources/*
!knowledge/user_private_sources/README.md
knowledge/licensed_sources/*
!knowledge/licensed_sources/README.md
knowledge/processed/*
!knowledge/processed/README.md
!knowledge/processed/.gitkeep

# .asc -> .cir cache files (regenerated by the M2.8 converter when the .asc changes)
examples/case_002_DCDC/input/ADM1281-3.cir

# M3 UI — Vite build output and Node toolchain.
ui/node_modules/
ui/dist/
src/emc_assistant/ui/web/

# UI design handoff zips dropped into the repo (gitignored to keep them out of git;
# the canonical source lives under ui/ after extraction).
*.zip
